{
  "table": "audit_log",
  "auto_increment": true,
  "primary_key": "id",
  "fields": {
    "id": "number",
    "store_id": "number|null",
    "user_id": "number|null",
    "action": "string",
    "resource_type": "string",
    "resource_id": "number|null",
    "details": "object|null",
    "ip_address": "string|null",
    "user_agent": "string|null",
    "created_at": "string"
  },
  "indexes": [
    { "name": "idx_audit_store_time","columns": ["store_id","created_at"],       "unique": false },
    { "name": "idx_audit_user_time", "columns": ["user_id","created_at"],        "unique": false },
    { "name": "idx_audit_resource",  "columns": ["resource_type","resource_id"], "unique": false },
    { "name": "idx_audit_time",      "columns": ["created_at"],                  "unique": false }
  ],
  "relations": [
    { "type": "belongs_to", "table": "stores", "local_key": "store_id", "foreign_key": "id" },
    { "type": "belongs_to", "table": "users",  "local_key": "user_id",  "foreign_key": "id" }
  ]
}
