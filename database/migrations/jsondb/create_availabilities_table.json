{
  "table": "availabilities",
  "auto_increment": true,
  "primary_key": "id",
  "fields": {
    "id": "number",
    "store_id": "number",
    "user_id": "number",
    "day_of_week": "number",
    "start_time": "string",
    "end_time": "string",
    "is_available": "number",
    "effective_from": "string|null",
    "effective_until": "string|null",
    "created_at": "string",
    "updated_at": "string|null"
  },
  "indexes": [
    { "name": "idx_avail_user_day",   "columns": ["user_id","day_of_week","is_available"],"unique": false },
    { "name": "idx_avail_store_user", "columns": ["store_id","user_id"],                  "unique": false }
  ],
  "relations": [
    { "type": "belongs_to", "table": "stores", "local_key": "store_id", "foreign_key": "id" },
    { "type": "belongs_to", "table": "users",  "local_key": "user_id",  "foreign_key": "id" }
  ]
}
